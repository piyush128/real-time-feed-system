{
  "info": {
    "name": "Real-Time Feed System",
    "description": "API collection for the Real-Time Notification + Activity Feed System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"alice@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/posts",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"caption\": \"Hello World!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Follow",
      "item": [
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/follow/:userId",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "variable": [
              { "key": "userId", "value": "2" }
            ]
          }
        },
        {
          "name": "Accept Follow Request",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/follow/:followerId/accept",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "variable": [
              { "key": "followerId", "value": "1" }
            ]
          }
        },
        {
          "name": "Reject Follow Request",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/follow/:followerId/reject",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "variable": [
              { "key": "followerId", "value": "1" }
            ]
          }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "Get Feed",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/feed",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
